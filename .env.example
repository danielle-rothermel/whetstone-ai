# Postgres connection for Alembic schema application and DBOS workers.
# Peer auth uses your OS role when no credentials appear in the URL.
DATABASE_URL=postgresql:///dr_dspy

# Hosted store URLs are secret-managed (mise run set-secret-env), never
# committed. NEON_DATABASE_URL must be the DIRECT Neon endpoint; pooled
# hosts (*-pooler.*.neon.tech) are rejected because they drop the startup
# search_path option that schema-bound boundaries require.
# MOTHERDUCK_DATABASE_URL=postgresql://...
# NEON_DATABASE_URL=postgresql://...direct-endpoint.neon.tech/...
